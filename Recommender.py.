import pandas as pd
from sklearn.feature_extraction.text import TfidfVectorizer
from sklearn.metrics.pairwise import cosine_similarity

# 1. Sample Data (Normally you'd use a big CSV file)
data = {
    'title': ['The Witcher', 'Money Heist', 'Stranger Things', 'Breaking Bad', 'Dark'],
    'description': ['Fantasy monster hunter magic', 'Bank heist mastermind thriller', 'Kids monsters upside down 80s', 'Chemistry teacher drug kingpin', 'Time travel mystery thriller']
}
df = pd.DataFrame(data)

# 2. Convert text to numbers (TF-IDF)
tfidf = TfidfVectorizer(stop_words='english')
tfidf_matrix = tfidf.fit_transform(df['description'])

# 3. Calculate Similarity
cosine_sim = cosine_similarity(tfidf_matrix, tfidf_matrix)

def get_recommendations(title):
    idx = df.index[df['title'] == title][0]
    sim_scores = list(enumerate(cosine_sim[idx]))
    sim_scores = sorted(sim_scores, key=lambda x: x[1], reverse=True)
    
    print(f"Because you watched {title}, you might like:")
    for i in sim_scores[1:3]:
        print("- " + df['title'].iloc[i[0]])

# Test it
get_recommendations('Money Heist')

